{
  "name": "yggdrasill",
  "displayName": "Yggdrasill",
  "description": "Harness relationship graph for Claude Code, inside VS Code. Skills, hooks, MCP, memory, plugins — and how they connect.",
  "version": "0.1.0",
  "license": "MIT",
  "publisher": "yusuke-oki-06",
  "author": {
    "name": "yusuke-oki-06"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yusuke-oki-06/yggdrasill"
  },
  "bugs": {
    "url": "https://github.com/yusuke-oki-06/yggdrasill/issues"
  },
  "homepage": "https://github.com/yusuke-oki-06/yggdrasill#readme",
  "icon": "media/yggdrasill-icon.png",
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=20"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "claude-code",
    "harness",
    "relationship",
    "graph",
    "blueprint",
    "skills",
    "hooks",
    "mcp",
    "memory",
    "observability"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "yggdrasill.hello",
        "title": "Yggdrasill: Hello",
        "category": "Yggdrasill"
      },
      {
        "command": "yggdrasill.openBlueprint",
        "title": "Yggdrasill: Open Blueprint",
        "category": "Yggdrasill",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "yggdrasill.refresh",
        "title": "Yggdrasill: Refresh Harness",
        "category": "Yggdrasill",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "yggdrasill.openBlueprint",
          "when": "view == yggdrasill.harness",
          "group": "navigation@1"
        },
        {
          "command": "yggdrasill.refresh",
          "when": "view == yggdrasill.harness",
          "group": "navigation@2"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "yggdrasill",
          "title": "Yggdrasill",
          "icon": "media/yggdrasill-icon.svg"
        }
      ]
    },
    "views": {
      "yggdrasill": [
        {
          "id": "yggdrasill.harness",
          "name": "Harness",
          "icon": "media/yggdrasill-icon.svg",
          "contextualTitle": "Yggdrasill Harness"
        }
      ]
    },
    "configuration": {
      "title": "Yggdrasill",
      "properties": {
        "yggdrasill.notifications.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show a notification when a Claude Code session requires user input (AskUserQuestion / ExitPlanMode / permission request)."
        },
        "yggdrasill.parser.memoryRoot": {
          "type": "string",
          "default": "",
          "description": "Optional absolute path to a Claude Code memory directory. When empty, Yggdrasill infers it from the current workspace."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.mjs --production",
    "dev": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.blueprint.json",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.23.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "elkjs": "^0.11.1",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^3.23.0"
  }
}
